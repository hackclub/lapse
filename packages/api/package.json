{
  "name": "@hackclub/lapse-api",
  "version": "2.0.0",
  "description": "SDK for the Lapse API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && tsc-alias --resolve-full-paths",
    "watch": "tsc -b && tsc-alias --resolve-full-paths -w",
    "prepare": "pnpm run build"
  },
  "keywords": [
    "lapse",
    "hack-club"
  ],
  "author": "Hack Club",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.6.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hackclub/lapse-shared": "workspace:*",
    "@orpc/contract": "^1.13.5",
    "zod": "^4.2.1"
  }
}
