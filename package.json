{
	"packageManager": "pnpm@10.25.0",
	"scripts": {
		"build": "pnpm --parallel run build",
		"dev": "pnpm --filter './packages/*' --parallel run build && pnpm --parallel run dev",
		"dev:watch-all": "pnpm --parallel run watch",
		"dev:setup-env": "pnpm run --filter @hackclub/lapse-devscripts dev:setup-env",
		"console": "pnpm tsx ./apps/server/etc/scripts/console.ts"
	}
}
