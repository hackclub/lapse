{
	"packageManager": "pnpm@10.25.0",
	"pnpm": {
		"overrides": {
			"protobufjs": "7.5.5",
			"@lookout/shared": "workspace:*"
		}
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"tsup": "^8.0.0"
	},
	"scripts": {
		"build": "pnpm --filter @lookout/shared run build && pnpm -r run build",
		"dev": "pnpm --filter './packages/*' --parallel run build && pnpm --parallel run dev",
		"dev:watch-all": "pnpm --parallel run watch",
		"dev:setup-env": "pnpm run --filter @hackclub/lapse-devscripts dev:setup-env",
		"dev:start-env": "pnpm run --filter @hackclub/lapse-devscripts dev:start-env",
		"dev:stop-env": "pnpm run --filter @hackclub/lapse-devscripts dev:stop-env",
		"dev:remove-env": "pnpm run --filter @hackclub/lapse-devscripts dev:remove-env",
		"console": "pnpm tsx ./apps/server/etc/scripts/console.ts"
	}
}
