{
  "name": "@hackclub/lapse-devscripts",
  "version": "2.0.0",
  "description": "Scripts useful for Lapse development",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:setup-env": "pnpm tsx ./src/setup-dev-env.ts --init",
    "dev:start-env": "pnpm tsx ./src/setup-dev-env.ts --only-docker",
