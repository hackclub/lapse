    "execa": "^9.6.1",
    "js-yaml": "^5.2.0",
    "ora": "^9.4.1",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1"
  }
