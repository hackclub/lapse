generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PermissionLevel {
  USER
  ADMIN
  ROOT
}

enum TimelapseVisibility {
  /// The timelapse should only be accessible from owner views or via direct URI access.
  UNLISTED

  /// The timelapse can be accessed via any means of discovery.
  PUBLIC

  /// Equivalent to `UNLISTED`, but cannot be changed, and indicates a timelapse that cannot be played.
  FAILED_PROCESSING
}

enum VideoContainerKind {
  WEBM
  MP4
}

enum ServiceClientTrustLevel {
  UNTRUSTED
  TRUSTED
}

/// Represents a device with an encryption passkey that is unknown to the server.
model KnownDevice {
  id      String        @id @default(uuid())
  name    String

  ownerId   String
  owner     User        @relation(fields: [ownerId], references: [id])

  /// The draft timelapses created on this device. When a draft timelapse is published, all device metadata
  /// is stripped.
  draftTimelapses     DraftTimelapse[]
}

/// Represents a single user of Lapse.
model User {
  id                        String            @id @default(nanoid(12))
  email                     String
  createdAt                 DateTime          @default(now())
  permissionLevel           PermissionLevel   @default(USER)
  handle                    String            @unique
  displayName               String
  profilePictureUrl         String
  bio                       String            @default("")
  urls                      String[]          @default([])
  hackatimeId               String?
  hackatimeAccessToken      String?
  hackatimeRefreshToken     String?
  slackId                   String?
  lastHeartbeat             DateTime          @default(now())
  lastHandleChangeAt        DateTime?

  timelapses            Timelapse[]
  devices               KnownDevice[]
  postedComments        Comment[]
  draftTimelapses       DraftTimelapse[]
  serviceTokenAudits    ServiceTokenAudit[]
  serviceGrants         ServiceGrant[]
  serviceClients        ServiceClient[]
  serviceClientReviews  ServiceClientReview[]
}

/// Represents a timelapse that is encrypted and awaits re-encoding. A `DraftTimelapse` is only displayed to the owner, and
/// may be composed of multiple recording sessions.
///
/// A `DraftTimelapse` is conceptually a different entity from `Timelapse` - it can be thought of as an editing project file, where
/// `Timelapse` is a ready, rendered video.
model DraftTimelapse {
  /// The unique ID of the timelapse.
  id                    String      @id @default(nanoid(12))

  /// The date and time when the draft timelapse has been created.
  createdAt             DateTime    @default(now())

  /// The name (title) of the timelapse. If `null`, this means that the timelapse has not yet been given a name by the author.
  name                  String?

  /// The description of the timelapse. This can contain a limited subset of Markdown (bold, italic, strikethrough, code).
  description           String                  @default("")

  /// The edit list associated with the timelapse. An entry in an edit list should conform to the following schema:
  ///
  /// ```ts
  ///   interface EditListEntry {
  ///       begin: number; // start time (in seconds) of the edit
  ///       end: number; // end time (in seconds) of the edit
  ///       kind: "CUT"; // "CUT" = remove region
  ///   }
  /// ```
  /// 
  /// Additional `kind` values might be supported in the future.
  editList                Json[]

  /// A list of S3 keys for all sessions of the timelapse.
  /// Each session is encrypted with the user's device key.
  sessions                String[]

  /// The S3 key pointing to the user-generated thumbnail.
  /// This is always encrypted with the user's device key.
  thumbnailKey            String

  /// Timestamps for each frame in the timelapse.
  snapshots               DateTime[]

  /// The 128-bit IV used to encrypt the draft, represented as a hex string. This is generated by the **server**.
  iv                      String

  /// If defined, this draft is currently in the process of being published. It should be considered immutable and hidden - draft timelapses
  /// that are being published usually get removed after processing, but in the event of an error, this field may be changed back to `null`,
  /// with the associated timelapse being marked as invalid.
  associatedTimelapseId   String?          @unique
  associatedTimelapse     Timelapse?       @relation(fields: [associatedTimelapseId], references: [id])

  deviceId              String
  device                KnownDevice        @relation(fields: [deviceId], references: [id])

  ownerId               String
  owner                 User               @relation(fields: [ownerId], references: [id])
}

/// Represents a published timelapse.
model Timelapse {
  /// The unique ID of the timelapse.
  id                    String                  @id @default(nanoid(12))

  /// The date when the timelapse was created.
  createdAt             DateTime

  /// The S3 key that points to the video. This may be `null` if `associatedJobId` is not `null`, which indicates the timelapse is still being processed.
  s3Key                 String?

  /// The S3 key that points to the thumbnail image. This may be `null` if `associatedJobId` is not `null`, which indicates the timelapse is still being processed.
  thumbnailS3Key        String?

  /// The Hackatime project key associated with the timelapse. If `null`, the timelapse has not
  /// yet been synchronized with Hackatime.
  hackatimeProject      String?

  /// The name (title) of the timelapse.
  name                  String

  /// The description of the timelapse. This can contain a limited subset of Markdown (bold, italic, strikethrough, code).
  description           String                  @default("")

  /// Specifies whether the timelapse can only be accessed via its URL.
  visibility            TimelapseVisibility     @default(UNLISTED)

  /// The amount of seconds that this timelapse lasts for. This is inferred from the snapshots.
  duration              Float

  /// The timestamps for each frame in the timelapse.
  snapshots             DateTime[]

  /// The BullMQ job ID associated with this timelapse. When not `null`, this means that the timelapse is currently being processed
  /// (e.g. encoding). The state of the job can be queried via BullMQ.
  associatedJobId       String?

  /// The ID of the draft timelapse that this timelapse was originally published from. This persists even after
  /// the draft is deleted or unlinked, allowing failed processing timelapses to link back to the original draft.
  sourceDraftId         String?

  ownerId               String
  owner                 User                @relation(fields: [ownerId], references: [id])

  comments              Comment[]
  associatedDraft       DraftTimelapse?
}

/// Represents a comment that belongs to a timelapse.
model Comment {
  /// The unique ID of the comment.
  id          String                  @id @default(nanoid(12))

  /// The ID of the user that created this comment.
  authorId      String
  author        User                  @relation(fields: [authorId], references: [id])

  timelapseId   String
  timelapse     Timelapse             @relation(fields: [timelapseId], references: [id])

  /// The content of the comment. This can contain a limited subset of Markdown (bold, italic, strikethrough, code).
  content     String

  /// The date when the comment was created.
  createdAt   DateTime                @default(now())
}

/// Represents an OAuth2 service client (app).
model ServiceClient {
  /// The *internal* ID of the service client. This should never be exposed to API callers - see `clientId` for the actual OAuth2 client ID.
  id                  String                       @id @default(uuid())

  /// The actual client ID used in OAuth2 operations of the app.
  clientId            String                       @unique

  /// An scrypt hash of the client secret, in the format of "<16 byte salt>:<64 byte hash>".
  clientSecretHash    String

  /// The user-friendly name of the service client.
  name                String

  /// A description of the service client.
  description         String                       @default("")

  /// The URL of the main page of the app.
  homepageUrl         String                       @default("")

  /// A URL to the icon of the app. May be empty.
  iconUrl             String                       @default("")

  /// The scopes that are available to this client.
  scopes              String[]                     @default([])

  /// The allowed redirect URIs.
  redirectUris        String[]                     @default([])

  /// Whether this OAuth2 app should be deemed trusted - untrusted apps should warnings when authenticating to let the user know that
  /// it is not an official Hack Club HQ app.
  trustLevel          ServiceClientTrustLevel      @default(UNTRUSTED)

  /// The ID of the owner of the client.
  createdByUserId     String?
  createdByUser       User?                        @relation(fields: [createdByUserId], references: [id])

  /// The time at which this client was created.
  createdAt           DateTime                     @default(now())

  /// The last time this record has been updated.
  updatedAt           DateTime                     @updatedAt

  /// The last time any application has authenticated with this client. `null` if never used.
  lastUsedAt          DateTime?

  /// The time at which this application has been revoked at. `null` if not revoked.
  revokedAt           DateTime?

  tokenAudits         ServiceTokenAudit[]
  grants              ServiceGrant[]
  reviews             ServiceClientReview[]
}

model ServiceTokenAudit {
  id               String        @id @default(uuid())
  serviceClientId  String
  serviceClient    ServiceClient @relation(fields: [serviceClientId], references: [id])
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  scope            String
  ip               String?
  userAgent        String?
  createdAt        DateTime      @default(now())
}

model ServiceGrant {
  id               String        @id @default(uuid())
  serviceClientId  String
  serviceClient    ServiceClient @relation(fields: [serviceClientId], references: [id])
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  scopes           String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  revokedAt        DateTime?
  lastUsedAt       DateTime?

  @@unique([serviceClientId, userId])
}

model ServiceClientReview {
  id               String        @id @default(uuid())
  serviceClientId  String
  serviceClient    ServiceClient @relation(fields: [serviceClientId], references: [id])
  reviewedByUserId String
  reviewedByUser   User          @relation(fields: [reviewedByUserId], references: [id])
  status           ServiceClientTrustLevel
  notes            String        @default("")
  createdAt        DateTime      @default(now())
}
