{
  "name": "@hackclub/lapse-server",
  "version": "2.0.0",
  "description": "The backend of Lapse",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "author": "Hack Club",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && pnpm tsc",
    "start": "pnpm run build && fastify start -l info dist/app.js",
    "watch": "tsc -w",
    "dev": "pnpm run build && pnpm exec concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm:watch\" \"pnpm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "dev:console": "tsx ./etc/scripts/console.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.994.0",
    "@aws-sdk/s3-request-presigner": "^3.994.0",
    "@hackclub/lapse-api": "workspace:*",
    "@hackclub/lapse-shared": "workspace:*",
    "@hackclub/lapse-worker": "workspace:*",
    "@orpc/openapi": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@prisma/adapter-pg": "^7.2.0",
    "@sentry/node": "^10.39.0",
    "@trpc/server": "^11.8.0",
    "bullmq": "^5.69.3",
    "dotenv": "^17.2.3",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "prisma": "^7.2.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@prisma/client": "^7.2.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "fastify": "^5.7.4",
    "typescript": "^5.9.3"
  }
}
