# This is an .env file meant for use in development environments only.
# Most of them are empty - make sure to fill them out! You can find detailed descriptions
# of each environment variable in `/apps/web/src/server/env.ts`.

# This should be a URL like "postgresql://postgres:postgres@localhost:5432/lapse?schema=public".
# See the README to get an example command on how to get a PostgreSQL database running locally!
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lapse?schema=public

# Redis is used by the worker to communicate with the server through BullMQ. Make sure both the server and the worker
# are connected to the same Redis database!
REDIS_URL=

# This is what we use to provide URLs to the API to external services. For example, we'd provide "$BASE_URL/auth/hackatimeCallback" to
# Hackatime for the callback URL.
BASE_URL=http://localhost:3123/api

# In the case where we can't get a profile picture for a user, this will be used instead.
# This should point to a permanent location - it will be saved to the database!
DEFAULT_PFP_URL=http://localhost:3000/images/default-pfp.png

# The port the web server will run on.
PORT=3123

# Lapse uses the same authentication flow for all OAuth clients - including the web app. However, one client is trusted with handling
# stuff like consent screens, and is allowed to bypass some security restrictions. On startup, the server will create or update the
# canonical client with these properties.
CANONICAL_OAUTH_CLIENT_ID=
CANONICAL_OAUTH_CLIENT_NAME=Lapse (web)
CANONICAL_OAUTH_CLIENT_DESCRIPTION=The official Lapse web client
CANONICAL_OAUTH_CLIENT_HOMEPAGE_URL=http://localhost:3000
CANONICAL_OAUTH_CLIENT_REDIRECT_URIS=http://localhost:3000/auth

# This would be something like "https://lapse.hackclub.com/api/auth-hackatime" for production.
HACKATIME_URL=https://hackatime.hackclub.com

# Slack bot token used to fetch user profile information (including profile pictures).
# Create a Slack app, enable the "users:read" scope, and generate a bot token.
SLACK_BOT_TOKEN=

# We use S3 to store all user content (timelapses, thumbnails, etc...) - if you don't have an S3 bucket at hand, you can set up
# Cloudflare R2 buckets completely for free. As Lapse itself uses R2, this should model production behavior quite closely.
#     1. Press CTRL+K to search, and look up "R2 object storage".
#     2. Create two buckets: "lapse-encrypted" and "lapse-public".
#     3. Set the CORS policy of both buckets to the following:
#        [{ "AllowedOrigins": ["*"], "AllowedMethods": ["GET", "PUT", "HEAD", "POST", "DELETE"], "AllowedHeaders": ["*"], "ExposeHeaders": ["ETag"], "MaxAgeSeconds": 3000 }]
# The S3 endpoint needs to be only the domain - do not include the "https://" prefix, please!
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENCRYPTED_BUCKET_NAME=lapse-encrypted
S3_PUBLIC_BUCKET_NAME=lapse-public

# Get this by going to Settings of each R2 bucket, and copying the Public Development URL.
S3_PUBLIC_URL_PUBLIC=
S3_PUBLIC_URL_ENCRYPTED=

# You can generate random keys for these, if you wish. For development, they only need to be valid hex strings.
PRIVATE_KEY_UPLOAD_KEY=deadc0de09d5febeba49820b3e34c283
JWT_CONSENT_TOKENS=deadc0defc25c6d4d250104c398c35b35c5e202da4ec568168598b1f952e499a
JWT_UPLOAD_TOKEN=deadc0defc25c6d4d250104c398c35b35c5e202da4ec568168598b1f952e499a
JWT_SECRET_ACCESS_TOKENS=deadc0defc25c6d4d250104c398c35b35c5e202da4ec568168598b1f952e499a

# This is related to Sentry - the error monitoring solution we use. In most cases, during development, you won't have to specify this.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
