    "@lookout/shared": "workspace:*",
    "@squircle-js/react": "^1.3.0",
    "@videojs/react": "^10.0.0-beta.8",
    "motion": "^12.38.0",
    "@orpc/client": "^1.14.3",
    "@orpc/contract": "^1.14.3",
    "@orpc/openapi": "^1.14.3",
    "@orpc/openapi-client": "^1.14.3",
    "@scure/bip39": "^2.2.0",
    "@types/platform": "^1.3.6",
    "clsx": "^2.1.1",
    "fetch-retry": "^6.0.0",
    "jsonrepair": "^3.14.0",
    "next": "^16.2.6",
    "platform": "^1.3.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
