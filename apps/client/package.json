    "@orpc/openapi": "^1.14.3",
    "@orpc/openapi-client": "^1.14.3",
    "@posthog/nextjs-config": "^1.9.29",
    "@scure/bip39": "^2.2.0",
    "@types/platform": "^1.3.6",
    "clsx": "^2.1.1",
    "fetch-retry": "^6.0.0",
