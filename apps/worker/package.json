{
  "name": "@hackclub/lapse-worker",
  "version": "2.0.0",
  "description": "Handles background jobs for the Lapse backend",
  "private": true,
  "type": "module",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "author": "Hack Club",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm tsc && tsc-alias",
    "watch": "tsc -w",
    "start": "pnpm build && node ./dist/app.js",
    "dev": "pnpm run build && pnpm run dev:start",
    "dev:start": "pnpm exec node ./dist/app.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/lib-storage": "^3.1033.0",
    "@hackclub/lapse-api": "workspace:*",
    "@hackclub/lapse-jobs": "workspace:*",
    "@hackclub/lapse-shared": "workspace:*",
    "@sentry/node": "^10.49.0",
    "bullmq": "^5.75.2",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.0.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
